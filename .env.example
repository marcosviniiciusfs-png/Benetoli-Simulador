# Copie este arquivo para .env.local e preencha com os valores reais.
# .env.local é gitignored automaticamente (padrão *.local).

# Projeto Supabase do Lovable (cliente público — ok bundlar)
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=

# Webhook externo de captura de leads
VITE_FORM_WEBHOOK_URL=
VITE_FORM_WEBHOOK_TOKEN=

# Endpoint da Edge Function CAPI (Meta Conversion API).
# Opcional: se omitido, usa o default hardcoded em src/lib/meta.ts
# (https://uxttihjsxfowursjyult.supabase.co/functions/v1/meta-event)
VITE_META_CAPI_URL=
