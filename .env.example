# Copie este arquivo para .env.local e preencha com os valores reais.
# .env.local é gitignored automaticamente (padrão *.local).

# Projeto Supabase do Lovable (cliente público — ok bundlar)
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=

# Webhook externo de captura de leads
VITE_FORM_WEBHOOK_URL=
VITE_FORM_WEBHOOK_TOKEN=

# Endpoint do Cloudflare Worker que faz proxy server-side pra Meta CAPI.
# Após `wrangler deploy` no diretório worker/, copie a URL impressa
# (algo como https://benetoli-meta-event.<subdominio>.workers.dev) aqui.
# Se ficar vazio, o Pixel client-side continua funcionando, mas a CAPI não dispara.
VITE_META_CAPI_URL=
